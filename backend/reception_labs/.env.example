# ═══════════════════════════════════════════════════════════════════════════════
# Sales Bot USA — Backend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your actual values.
# 
# REQUIRED: ELEVENLABS_API_KEY
# OPTIONAL: Everything else (uses sensible defaults or mock mode)

# ─── ElevenLabs AI (REQUIRED) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Webhook secret for signature verification (RECOMMENDED for production)
# Get this from: ElevenLabs Dashboard → Conversational AI → Webhooks
ELEVENLABS_WEBHOOK_SECRET=wsec_your_webhook_secret_here

# Optional: Regional API endpoint override (default: api.us.elevenlabs.io)
# ELEVENLABS_BASE_URL=https://api.us.elevenlabs.io/v1

# ─── Stripe Payment Gateway (OPTIONAL) ───────────────────────────────────────
# Without these, the app runs in MOCK MODE (no real charges, testing only)
# Get keys from: https://dashboard.stripe.com/apikeys

# Test mode (for development)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# For production, use live keys:
# STRIPE_SECRET_KEY=sk_live_your_production_key
# STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# Optional: Custom secret for signing mock payment tokens (auto-generated if not set)
# MOCK_PAYMENT_SECRET=your_random_secret_for_dev_testing

# ─── Frontend URL (REQUIRED for payments and emails) ─────────────────────────
# Used for Stripe redirect URLs and email links
FRONTEND_URL=http://localhost:8080

# For production:
# FRONTEND_URL=https://yourdomain.com

# ─── SMTP Email Service (OPTIONAL) ───────────────────────────────────────────
# Without these, email notifications are disabled (app still works)
# Configure your SMTP server or use a service like Gmail, SendGrid, etc.

SMTP_HOST=mail.2ndwaveai.com
SMTP_PORT=587
SMTP_USER=support@2ndwaveai.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=Sales Bot USA <support@2ndwaveai.com>
SMTP_USE_TLS=true

# For Gmail (use App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# SMTP_FROM=Your Name <you@gmail.com>
# SMTP_USE_TLS=true

# ─── MongoDB Database (OPTIONAL) ─────────────────────────────────────────────
# If MONGODB_URI is set and reachable, uses MongoDB for storage
# If unset or unreachable, automatically falls back to JSON files

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=sales_bot_usa

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sales_bot_usa?retryWrites=true&w=majority

# For authenticated local MongoDB:
# MONGODB_URI=mongodb://admin:password@localhost:27017/sales_bot_usa?authSource=admin

# ─── Advanced Settings (OPTIONAL) ────────────────────────────────────────────
# How often to poll ElevenLabs for completed conversations (fallback mechanism)
# CALL_POLL_INTERVAL_SECONDS=60

# Estimated LLM tokens consumed per minute of conversation (for usage tracking)
# TOKENS_PER_MINUTE=800

# Usage alert threshold (percentage - default 80%)
# USAGE_ALERT_THRESHOLD=0.80

