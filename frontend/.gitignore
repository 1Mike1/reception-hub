# ================================
# Frontend - .gitignore
# ================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules
.pnp
.pnp.js

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist
dist-ssr
build
.next
out

# ─── Testing / Coverage ───────────────────────────────────────────────────────
coverage
.nyc_output

# ─── Environment Variables ────────────────────────────────────────────────────
*.env
.env
.env.local
.env.*.local
.env.production.local
.env.development.local
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── OS Specific ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.Spotlight-V100
.Trashes

# ─── Cache / Temporary ────────────────────────────────────────────────────────
*.local
.cache
.parcel-cache
.eslintcache
.stylelintcache
.turbo

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Lock Files (optional - uncomment to ignore) ──────────────────────────────
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
bun.lockb

# ─── Misc ─────────────────────────────────────────────────────────────────────
.vercel
.netlify
.firebase

# Supabase (local dev)
supabase/.branches
supabase/.temp
supabase/functions/.env
